<%- include('partials/header') %>

<main class="container py-4 groups-container page-shell page-groups">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
    <div>
      <h1 class="h2 mb-1 page-title">Grupos</h1>
    </div>
    <a href="/auth/logout" class="btn btn-outline-secondary">Cerrar sesion</a>
  </div>

  <div class="card shadow-sm border-0 app-panel mb-3">
    <div class="card-body">
      <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <h3 class="h5 mb-0">Selecciona los grupos a los que quieres unirte</h3>
        <div class="d-flex flex-wrap gap-2">
          <button id="generateBtn" class="btn btn-primary btn-sm" onclick="sendGroupAccessRequest()" disabled>Enviar petición</button>
        </div>
      </div>
      <p class="mt-3 mb-0 fw-semibold">Seleccionados: <span id="selectedCount">0</span> grupos</p>
    </div>
  </div>

  <!-- Listas de Distribución -->
  <div class="card shadow-sm border-0 app-panel mb-4">
    <div class="card-body">
      <h3 class="h5 mb-3">Listas de Distribución</h3>
      <% if (distributionLists && distributionLists.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th style="width: 50px;"></th>
                <th>Estado</th>
                <th>Nombre</th>
                <th>Correo</th>
              </tr>
            </thead>
            <tbody>
              <% distributionLists.forEach(function(group) { %>
                <tr class="<%= group.isMember ? 'table-secondary' : '' %>">
                  <td>
                    <% if (!group.isMember) { %>
                      <input class="form-check-input group-checkbox" type="checkbox" data-group-id="<%= group.id %>" data-group-name="<%= group.displayName %>" onchange="updateSelection()">
                    <% } %>
                  </td>
                  <td><%= group.isMember ? 'Miembro' : 'No miembro' %></td>
                  <td><strong><%= group.displayName %></strong></td>
                  <td><%= group.mail %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-muted">No hay listas de distribución.</p>
      <% } %>
    </div>
  </div>

  <!-- Grupos de Herramientas Microsoft 365 - Ayuntamiento de Aranda de Duero -->
  <div class="card shadow-sm border-0 app-panel mb-4">
    <div class="card-body">
      <h3 class="h5 mb-3">Grupos de Herramientas Microsoft 365 - Ayuntamiento de Aranda de Duero</h3>
      <% if (m365Groups && m365Groups.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th style="width: 50px;"></th>
                <th>Estado</th>
                <th>Nombre</th>
              </tr>
            </thead>
            <tbody>
              <% m365Groups.forEach(function(group) { %>
                <tr class="<%= group.isMember ? 'table-secondary' : '' %>">
                  <td>
                    <% if (!group.isMember) { %>
                      <input class="form-check-input group-checkbox" type="checkbox" data-group-id="<%= group.id %>" data-group-name="<%= group.displayName %>" onchange="updateSelection()">
                    <% } %>
                  </td>
                  <td><%= group.isMember ? 'Miembro' : 'No miembro' %></td>
                  <td><strong><%= group.displayName %></strong></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-muted">No hay grupos de Microsoft 365.</p>
      <% } %>
    </div>
  </div>


  <div class="modal fade" id="reportDialog" tabindex="-1" aria-labelledby="groupsReportDialogLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="groupsReportDialogLabel">Solicitud de acceso a grupos</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <p>Se enviara un email con la solicitud de acceso a los siguientes grupos:</p>
          <ul id="selectedGroupsList"></ul>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary" onclick="submitGroupRequest()">Enviar email</button>
          <button type="button" class="btn btn-outline-secondary" onclick="closeDialog()">Cancelar</button>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  let selectedGroups = [];
  let reportModal;

  function getReportModal() {
    if (!reportModal) {
      const modalElement = document.getElementById('reportDialog');
      reportModal = bootstrap.Modal.getOrCreateInstance(modalElement);
    }
    return reportModal;
  }

  function updateSelection() {
    const checkboxes = document.querySelectorAll('.group-checkbox');
    selectedGroups = [];

    checkboxes.forEach(cb => {
      if (cb.checked) {
        selectedGroups.push({
          id: cb.dataset.groupId,
          name: cb.dataset.groupName
        });
      }
    });

    document.getElementById('selectedCount').textContent = selectedGroups.length;
    document.getElementById('generateBtn').disabled = selectedGroups.length === 0;
  }

  function selectAllNonMember() {
    document.querySelectorAll('.group-checkbox').forEach(cb => {
      cb.checked = true;
    });
    updateSelection();
  }

  function clearSelection() {
    document.querySelectorAll('.group-checkbox').forEach(cb => {
      cb.checked = false;
    });
    updateSelection();
  }

  function sendGroupAccessRequest() {
    if (selectedGroups.length === 0) return;
    
    const list = document.getElementById('selectedGroupsList');
    list.innerHTML = '';
    selectedGroups.forEach(g => {
      const li = document.createElement('li');
      li.textContent = g.name;
      list.appendChild(li);
    });
    
    getReportModal().show();
  }

  async function submitGroupRequest() {
    if (selectedGroups.length === 0) return;

    try {
      const response = await fetch('/api/group-access-request', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          selectedGroups: selectedGroups.map(g => g.id)
        })
      });

      const data = await response.json();

      if (data.success) {
        alert('Solicitud de acceso enviada correctamente');
        getReportModal().hide();
      } else {
        alert('Error al enviar la solicitud: ' + (data.error || 'Error desconocido'));
      }
    } catch (error) {
      console.error('Error sending request:', error);
      alert('No se pudo enviar la solicitud. Intentalo de nuevo.');
    }
  }

  function closeDialog() {
    getReportModal().hide();
  }
</script>

<%- include('partials/footer')%>
