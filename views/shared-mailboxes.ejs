<%- include('partials/header') %>

<main class="groups-container">
  <div class="groups-header">
    <div>
      <h1>Shared Mailboxes</h1>
      <p class="groups-stats">
        Access to <%= accessCount %> out of <%= totalCount %> shared mailboxes
      </p>
    </div>
    <fluent-button appearance="stealth" onclick="window.location.href='/auth/logout'">
      Logout
    </fluent-button>
  </div>

  <!-- Shared Mailboxes Actions -->
  <fluent-card class="groups-actions">
    <div class="action-header">
      <h3>Select shared mailboxes you need access to</h3>
      <div class="action-buttons">
        <fluent-button id="selectAllBtn" appearance="outline" onclick="selectAllNoAccess()">
          Select All Without Access
        </fluent-button>
        <fluent-button id="clearBtn" appearance="outline" onclick="clearSelection()">
          Clear Selection
        </fluent-button>
        <fluent-button id="generateBtn" appearance="accent" onclick="generateReport()" disabled>
          Generate Report
        </fluent-button>
      </div>
    </div>
    <p class="selected-count">Selected: <span id="selectedCount">0</span> mailboxes</p>
  </fluent-card>

  <!-- Shared Mailboxes Table -->
  <fluent-card class="groups-list-card">
    <h3>All Shared Mailboxes</h3>
    <fluent-divider></fluent-divider>
    
    <% if (allMailboxes && allMailboxes.length > 0) { %>
      <div class="groups-table">
        <div class="table-header">
          <div class="col-checkbox"></div>
          <div class="col-status">Status</div>
          <div class="col-name">Mailbox Name</div>
          <div class="col-email">Email</div>
          <div class="col-type">UPN</div>
        </div>
        
        <% allMailboxes.forEach(function(mailbox) { %>
          <div class="table-row <%= mailbox.hasAccess ? 'is-member' : 'not-member' %>">
            <div class="col-checkbox">
              <% if (!mailbox.hasAccess) { %>
                <fluent-checkbox 
                  class="mailbox-checkbox" 
                  data-mailbox-id="<%= mailbox.id %>"
                  data-mailbox-name="<%= mailbox.displayName %>"
                  onchange="updateSelection()">
                </fluent-checkbox>
              <% } %>
            </div>
            
            <div class="col-status">
              <% if (mailbox.hasAccess) { %>
                <span class="status-badge member">✓ Access</span>
              <% } else { %>
                <span class="status-badge non-member">✗ No Access</span>
              <% } %>
            </div>
            
            <div class="col-name">
              <strong><%= mailbox.displayName %></strong>
            </div>
            
            <div class="col-email">
              <% if (mailbox.mail) { %>
                <%= mailbox.mail %>
              <% } else { %>
                <span class="no-email">—</span>
              <% } %>
            </div>
            
            <div class="col-type">
              <% if (mailbox.userPrincipalName) { %>
                <span class="upn-text"><%= mailbox.userPrincipalName %></span>
              <% } else { %>
                <span class="no-email">—</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="no-groups">No shared mailboxes found in the tenant.</p>
    <% } %>
  </fluent-card>

  <!-- Report Modal -->
  <fluent-dialog id="reportDialog" modal hidden>
    <div class="dialog-content">
      <h2>Shared Mailboxes Access Request Report</h2>
      <fluent-divider></fluent-divider>
      <fluent-text-area id="reportText" rows="20" readonly resize="vertical"></fluent-text-area>
      <div class="dialog-actions">
        <fluent-button appearance="accent" onclick="copyReport()">
          Copy to Clipboard
        </fluent-button>
        <fluent-button appearance="outline" onclick="closeDialog()">
          Close
        </fluent-button>
      </div>
    </div>
  </fluent-dialog>
</main>

<script>
  let selectedMailboxes = [];

  function updateSelection() {
    const checkboxes = document.querySelectorAll('.mailbox-checkbox');
    selectedMailboxes = [];
    
    checkboxes.forEach(cb => {
      if (cb.checked) {
        selectedMailboxes.push({
          id: cb.dataset.mailboxId,
          name: cb.dataset.mailboxName
        });
      }
    });
    
    document.getElementById('selectedCount').textContent = selectedMailboxes.length;
    document.getElementById('generateBtn').disabled = selectedMailboxes.length === 0;
  }

  function selectAllNoAccess() {
    const checkboxes = document.querySelectorAll('.mailbox-checkbox');
    checkboxes.forEach(cb => {
      cb.checked = true;
    });
    updateSelection();
  }

  function clearSelection() {
    const checkboxes = document.querySelectorAll('.mailbox-checkbox');
    checkboxes.forEach(cb => {
      cb.checked = false;
    });
    updateSelection();
  }

  async function generateReport() {
    if (selectedMailboxes.length === 0) return;
    
    try {
      const response = await fetch('/shared-mailboxes/generate-report', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          selectedMailboxes: selectedMailboxes.map(mb => mb.id)
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        document.getElementById('reportText').value = data.report;
        document.getElementById('reportDialog').removeAttribute('hidden');
      } else {
        alert('Error generating report: ' + (data.error || 'Unknown error'));
      }
    } catch (error) {
      console.error('Error generating report:', error);
      alert('Failed to generate report. Please try again.');
    }
  }

  function copyReport() {
    const reportText = document.getElementById('reportText').value;
    navigator.clipboard.writeText(reportText).then(() => {
      alert('Report copied to clipboard!');
    }).catch(err => {
      console.error('Failed to copy:', err);
      alert('Failed to copy to clipboard. Please copy manually.');
    });
  }

  function closeDialog() {
    document.getElementById('reportDialog').setAttribute('hidden', '');
  }
</script>

<style>
  .groups-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .groups-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
  }

  .groups-stats {
    color: var(--neutral-foreground-rest);
    margin-top: 0.5rem;
    font-size: 0.95rem;
  }

  .groups-actions {
    margin-bottom: 1.5rem;
    padding: 1.5rem;
  }

  .action-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .action-header h3 {
    margin: 0;
  }

  .action-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .selected-count {
    margin: 0;
    font-weight: 600;
    color: var(--accent-foreground-rest);
  }

  .groups-list-card {
    padding: 1.5rem;
  }

  .groups-list-card h3 {
    margin-top: 0;
  }

  .groups-table {
    margin-top: 1rem;
  }

  .table-header,
  .table-row {
    display: grid;
    grid-template-columns: 40px 140px 1fr 250px 250px;
    gap: 1rem;
    padding: 0.75rem;
    align-items: center;
  }

  .table-header {
    font-weight: 600;
    border-bottom: 2px solid var(--neutral-stroke-rest);
    background: var(--neutral-layer-2);
  }

  .table-row {
    border-bottom: 1px solid var(--neutral-stroke-rest);
    transition: background-color 0.2s;
  }

  .table-row:hover {
    background: var(--neutral-layer-1);
  }

  .table-row.is-member {
    opacity: 0.7;
  }

  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .status-badge.member {
    background: #10b981;
    color: white;
  }

  .status-badge.non-member {
    background: #ef4444;
    color: white;
  }

  .no-email {
    color: var(--neutral-foreground-hint);
  }

  .upn-text {
    font-size: 0.85rem;
    color: var(--neutral-foreground-rest);
  }

  .no-groups {
    padding: 2rem;
    text-align: center;
    color: var(--neutral-foreground-hint);
  }

  .dialog-content {
    padding: 1.5rem;
    min-width: 600px;
  }

  .dialog-content h2 {
    margin-top: 0;
  }

  .dialog-content fluent-text-area {
    width: 100%;
    margin: 1rem 0;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
  }

  .dialog-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }
</style>

<%- include('partials/footer')%>
