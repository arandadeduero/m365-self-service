<%- include('partials/header') %>

<main class="error-container">
  <fluent-card class="error-card">
    <h1>Development Error</h1>
    <fluent-divider></fluent-divider>
    
    <div class="error-details">
      <div class="error-section">
        <h2>Error Information</h2>
        <p><strong>Status:</strong> <%= error.status %></p>
        <p><strong>Message:</strong> <%= error.message %></p>
        <p><strong>Timestamp:</strong> <%= error.timestamp %></p>
      </div>

      <div class="error-section">
        <h2>Request Details</h2>
        <p><strong>URL:</strong> <%= error.url %></p>
        <p><strong>Method:</strong> <%= error.method %></p>
      </div>

      <% if (error.session) { %>
        <div class="error-section">
          <h2>Session Status</h2>
          <p><strong>Has Access Token:</strong> <%= error.session.hasAccessToken ? 'Yes' : 'No' %></p>
          <p><strong>Has Account:</strong> <%= error.session.hasAccount ? 'Yes' : 'No' %></p>
        </div>
      <% } %>

      <div class="error-section">
        <h2>Stack Trace</h2>
        <pre class="stack-trace"><%= error.stack %></pre>
      </div>

      <% if (error.query && Object.keys(error.query).length > 0) { %>
        <div class="error-section">
          <h2>Query Parameters</h2>
          <pre><%= JSON.stringify(error.query, null, 2) %></pre>
        </div>
      <% } %>

      <% if (error.body && Object.keys(error.body).length > 0) { %>
        <div class="error-section">
          <h2>Request Body</h2>
          <pre><%= JSON.stringify(error.body, null, 2) %></pre>
        </div>
      <% } %>
    </div>

    <div class="error-actions">
      <fluent-button appearance="accent" onclick="window.location.href='/'">
        Go to Home
      </fluent-button>
      <fluent-button appearance="stealth" onclick="window.location.href='/login'">
        Go to Login
      </fluent-button>
    </div>
  </fluent-card>
</main>

<%- include('partials/footer') %>
