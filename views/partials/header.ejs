<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - M365 Login Demo</title>
  
  <!-- Fluent UI Web Components -->
  <script type="module" src="https://unpkg.com/@fluentui/web-components@beta"></script>
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body>
  <% if (typeof currentPage !== 'undefined' && currentPage !== 'login') { %>
  <nav class="app-navigation">
    <div class="nav-container">
      <div class="nav-brand">
        <h2>M365 Manager</h2>
      </div>
      <div class="nav-links">
        <a href="/" class="nav-link <%= currentPage === 'profile' ? 'active' : '' %>">
          Profile
        </a>
        <a href="/groups" class="nav-link <%= currentPage === 'groups' ? 'active' : '' %>">
          Groups
        </a>
        <a href="/distribution-lists" class="nav-link <%= currentPage === 'distribution-lists' ? 'active' : '' %>">
          Distribution Lists
        </a>
        <a href="/shared-mailboxes" class="nav-link <%= currentPage === 'shared-mailboxes' ? 'active' : '' %>">
          Shared Mailboxes
        </a>
      </div>
    </div>
  </nav>
  <% } %>
