<%- include('partials/header') %>

<main class="container py-5 error-container error-production page-shell page-error">
  <div class="card shadow-sm border-0 app-panel error-card-prod text-center">
    <div class="card-body p-4 p-md-5">
      <div class="error-status">
        <h1 class="status-code"><%= statusCode %></h1>
      </div>

      <hr>

      <div class="error-message">
        <% if (statusCode === 401) { %>
          <h2>Autenticacion requerida</h2>
          <p>Inicia sesion para continuar</p>
        <% } else if (statusCode === 403) { %>
          <h2>Acceso denegado</h2>
          <p>No tienes permiso para acceder a este recurso</p>
        <% } else if (statusCode === 404) { %>
          <h2>Pagina no encontrada</h2>
          <p>La pagina que buscas no existe</p>
        <% } else if (statusCode === 500) { %>
          <h2>Error interno del servidor</h2>
          <p>Algo salio mal de nuestro lado</p>
        <% } else { %>
          <h2>Error</h2>
          <p>Ocurrio un error inesperado</p>
        <% } %>
      </div>

      <div class="mt-4">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
