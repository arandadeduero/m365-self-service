<%- include('partials/header') %>

<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Organigrama</h1>
    <div style="position: relative; width: 300px;">
      <input type="text" id="search-input" placeholder="Buscar usuario..." class="form-control">
      <div id="search-results" class="list-group" style="position: absolute; z-index: 1000; width: 100%; max-height: 200px; overflow-y: auto;"></div>
    </div>
  </div>
  <div class="chart-container" style="height: 1200px; background-color: #f6f6f6; width: 100%; overflow: auto;"></div>
</main>

<!-- Load D3 and the Org Chart library from a CDN -->
<script src="https://d3js.org/d3.v7.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3-org-chart@3"></script>
<script src="https://cdn.jsdelivr.net/npm/d3-flextree@2.1.2/build/d3-flextree.js"></script>

<script>
  // Datos traídos del servidor
  const rawData = <%- users %>;
  
  // Transformación de datos para la librería d3-org-chart
  const data = rawData.map(user => ({
    id: user.id,
    name: user.displayName,
    positionName: user.jobTitle || 'Empleado',
    email: user.mail,
    parentId: user.managerId,
    imageUrl: 'https://raw.githubusercontent.com/bumbeishvili/sample-data/main/org.csv' // Placeholder
  }));

  // Buscar el usuario "alinaje@arandadeduero.es" para que sea la raíz
  const rootUserEmail = 'alinaje@arandadeduero.es';
  const rootUser = data.find(u => u.email && u.email.toLowerCase() === rootUserEmail);

  let chartData = data;
  
  if (rootUser) {
    // Construir mapa de hijos
    const childrenMap = new Map();
    data.forEach(u => {
      if(u.parentId) {
        if(!childrenMap.has(u.parentId)) childrenMap.set(u.parentId, []);
        childrenMap.get(u.parentId).push(u);
      }
    });

    // Recolectar raíz y todos sus descendientes
    const subset = [rootUser];
    const queue = [rootUser.id];
    
    while(queue.length > 0) {
      const currentId = queue.shift();
      const children = childrenMap.get(currentId) || [];
      children.forEach(child => {
        subset.push(child);
        queue.push(child.id);
      });
    }
    chartData = subset;
  }

  // Inicializar el organigrama
  const chart = new d3.OrgChart()
    .container('.chart-container')
    .data(chartData)
    .nodeId(d => d.id)
    .parentNodeId(d => d.parentId)
    .nodeWidth((d) => 250)
    .initialZoom(0.7)
    .nodeHeight((d) => 175)
    .childrenMargin((d) => 40)
    .compactMarginBetween((d) => 15)
    .compactMarginPair((d) => 80)
    .nodeContent(function (d, i, arr, state) {
      return `
        <div style="padding-top:30px;background-color:none;margin-left:1px;height:${d.height}px;border-radius:2px;overflow:visible">
          <div style="height:${d.height - 32}px;padding-top:0px;background-color:white;border:1px solid lightgray;">
            <img src="https://ui-avatars.com/api/?name=${encodeURIComponent(d.data.name)}&background=random" style="margin-top:-30px;margin-left:${d.width / 2 - 30}px;border-radius:100px;width:60px;height:60px;" />
            <div style="margin-right:10px;margin-top:10px;float:right">
              <a href="https://teams.microsoft.com/l/chat/0/0?users=${d.data.email}" target="_blank" style="text-decoration:none; color: #6264A7; font-size: 12px; font-weight: bold; display: flex; align-items: center;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 4px;">
                  <path d="M20.5,12.5C21.33,12.5 22,13.17 22,14V18C22,18.83 21.33,19.5 20.5,19.5H16.5C15.67,19.5 15,18.83 15,18V14C15,13.17 15.67,12.5 16.5,12.5H20.5M20.5,13.5H16.5C16.22,13.5 16,13.72 16,14V18C16,18.28 16.22,18.5 16.5,18.5H20.5C20.78,18.5 21,18.28 21,18V14C21,13.72 20.78,13.5 20.5,13.5M13.5,12.5H9.5C8.67,12.5 8,13.17 8,14V18C8,18.83 8.67,19.5 9.5,19.5H13.5C14.33,19.5 15,18.83 15,18V14C15,13.17 14.33,12.5 13.5,12.5M13.5,13.5C13.78,13.5 14,13.72 14,14V18C14,18.28 13.78,18.5 13.5,18.5H9.5C9.22,18.5 9,18.28 9,18V14C9,13.72 9.22,13.5 9.5,13.5H13.5M6.5,12.5H2.5C1.67,12.5 1,13.17 1,14V18C1,18.83 1.67,19.5 2.5,19.5H6.5C7.33,19.5 8,18.83 8,18V14C8,13.17 7.33,12.5 6.5,12.5M6.5,13.5C6.78,13.5 7,13.72 7,14V18C7,18.28 6.78,18.5 6.5,18.5H2.5C2.22,18.5 2,18.28 2,18V14C2,13.72 2.22,13.5 2.5,13.5H6.5M16.5,6.5H12.5C11.67,6.5 11,7.17 11,8V12C11,12.83 11.67,13.5 12.5,13.5H16.5C17.33,13.5 18,12.83 18,12V8C18,7.17 17.33,6.5 16.5,6.5M16.5,7.5C16.78,7.5 17,7.72 17,8V12C17,12.28 16.78,12.5 16.5,12.5H12.5C12.22,12.5 12,12.28 12,12V8C12,7.72 12.22,7.5 12.5,7.5H16.5M9.5,6.5H5.5C4.67,6.5 4,7.17 4,8V12C4,12.83 4.67,13.5 5.5,13.5H9.5C10.33,13.5 11,12.83 11,12V8C11,7.17 10.33,6.5 9.5,6.5M9.5,7.5C9.78,7.5 10,7.72 10,8V12C10,12.28 9.78,12.5 9.5,12.5H5.5C5.22,12.5 5,12.28 5,12V8C5,7.72 5.22,7.5 5.5,7.5H9.5M15.5,4.5H11.5C10.67,4.5 10,5.17 10,6V10C10,10.83 10.67,11.5 11.5,11.5H15.5C16.33,11.5 17,10.83 17,10V6C17,5.17 16.33,4.5 15.5,4.5M15.5,5.5C15.78,5.5 16,5.72 16,6V10C16,10.28 15.78,10.5 15.5,10.5H11.5C11.22,10.5 11,10.28 11,10V6C11,5.72 11.22,5.5 11.5,5.5H15.5Z" />
                </svg>
                Chatear
              </a>
            </div>
            <div style="margin-top:-30px;background-color:#3AB6E3;height:10px;width:${d.width - 2}px;border-radius:1px"></div>
            <div style="padding:20px; padding-top:35px;text-align:center">
              <a href="https://teams.microsoft.com/l/chat/0/0?users=${d.data.email}" target="_blank" style="color:#111672;text-decoration:none;font-size:16px;font-weight:bold"> ${d.data.name} </a>
              <div style="color:#404040;font-size:16px;margin-top:4px"> ${d.data.positionName} </div>
            </div> 
            <div style="display:flex;justify-content:space-between;padding-left:15px;padding-right:15px;">
              <div> Subordinados: ${d.data._directSubordinates} 👤</div>  
              <div> Total: ${d.data._totalSubordinates} 👤</div>    
            </div>
          </div>     
        </div>
      `;
    })
    .render();
    
  if (rootUser) {
    chart.setCentered(rootUser.id);
  }

  // Search logic
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  
  searchInput.addEventListener('input', (e) => {
    const term = e.target.value.toLowerCase();
    searchResults.innerHTML = '';
    if (term.length < 2) return;
    
    const matches = chartData.filter(d => d.name.toLowerCase().includes(term));
    matches.forEach(match => {
        const item = document.createElement('a');
        item.href = '#';
        item.className = 'list-group-item list-group-item-action';
        item.textContent = match.name;
        item.onclick = (e) => {
            e.preventDefault();
            
            // Expand all parents
            const expandParents = (id) => {
                const node = chartData.find(d => d.id === id);
                if (node && node.parentId) {
                    chart.expand(node.parentId);
                    expandParents(node.parentId);
                }
            };
            expandParents(match.id);
            chart.expand(match.id);

            // Delay centering to ensure expansion layout has processed
            setTimeout(() => {
                chart.setCentered(match.id);
            }, 150);

            searchResults.innerHTML = '';
            searchInput.value = match.name;
        };
        searchResults.appendChild(item);
    });
  });
</script>

<%- include('partials/footer') %>
