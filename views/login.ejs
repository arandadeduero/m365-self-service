<%- include('partials/header') %>

<main class="container py-5 page-shell page-login">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-7">
      <div class="card shadow-sm border-0 app-panel">
        <div class="card-body p-4 p-md-5 text-center">
          <h1 class="h2 mb-3 page-title">Bienvenido a Herramientas Microsoft 365 - Ayuntamiento de Aranda de Duero</h1>
          <p class="text-secondary mb-4">Inicia sesion con tu cuenta de Microsoft 365 para acceder a tu perfil.</p>

          <a href="/auth/signin" class="btn btn-primary btn-lg px-4">Iniciar sesion con Microsoft</a>
          
          <div class="mt-3">
            <a href="/reset-password" class="text-decoration-none">¿Has olvidado tu contraseña?</a>
          </div>

          <div class="alert alert-light text-start mt-4 mb-0">
            <p class="mb-2"><strong>Lo que veras despues de iniciar sesion:</strong></p>
            <ul class="mb-0">
              <li>Informacion de tu perfil</li>
              <li>Foto de perfil</li>
              <li>Pertenencia a grupos</li>
              <li>Datos del responsable</li>
              <li>Datos JSON en bruto</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
