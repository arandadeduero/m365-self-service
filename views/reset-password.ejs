<%- include('partials/header') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h2 class="h3 mb-4">Recuperar contraseña</h2>
          <p class="text-secondary mb-4">
            Si estás intentando entrar en Microsoft 365, ya sea por primera vez o porque has olvidado la contraseña, por favor, escribe aquí tu correo electrónico. Recibirás un enlace en tu cuenta para poder resetear tu contraseña.
          </p>

          <form action="/reset-password" method="POST">
            <div class="mb-3">
              <label for="email" class="form-label">Correo electrónico</label>
              <input type="email" class="form-control" id="email" name="email" required pattern=".*@arandadeduero\.es$" title="El correo electrónico debe terminar en @arandadeduero.es">
            </div>
            
            <div class="alert alert-warning d-flex align-items-start mb-3" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2 flex-shrink-0"></i>
              <div>
                <strong>Importante:</strong> El correo de recuperación llegará desde la dirección <strong>no-responder@arandadeduero.dev</strong>. 
                Por favor, revisa tu carpeta de SPAM si no lo recibes en unos minutos.
              </div>
            </div>
            
            <button type="submit" class="btn btn-primary w-100">Enviar enlace de reseteo</button>
          </form>
          
          <div class="mt-3 text-center">
            <a href="/login" class="text-decoration-none">Volver a inicio de sesión</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
