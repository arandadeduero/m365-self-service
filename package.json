{
  "name": "example-login-m365",
  "version": "1.0.0",
  "description": "Microsoft 365 login demo with Fluent UI and extended user data",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test c8 ava",
    "test:watch": "NODE_ENV=test ava --watch",
    "coverage": "c8 report --reporter=html --reporter=text"
  },
  "keywords": [
    "microsoft-365",
    "azure-ad",
    "entra-id",
    "oauth2",
    "authentication",
    "fluent-ui",
    "express",
    "msal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/msal-node": "^5.2.3",
    "@fluentui/tokens": "^1.0.0",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "timeout": "2m",
    "verbose": true,
    "nodeArguments": [
      "--no-warnings"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "test/**",
      "node_modules/**"
    ],
    "all": true
  }
}
