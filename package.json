{
  "name": "herramientas-microsoft-365-ayuntamiento-aranda-de-duero",
  "version": "1.0.0",
  "description": "Herramientas Microsoft 365 - Ayuntamiento de Aranda de Duero",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test ava",
    "test:watch": "NODE_ENV=test ava --watch",
    "coverage": "echo 'Coverage disabled for Node.js v26+ due to c8 compatibility issues'"
  },
  "keywords": [
    "microsoft-365",
    "azure-ad",
    "entra-id",
    "oauth2",
    "authentication",
    "express",
    "msal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1072.0",
    "@azure/msal-node": "^5.3.0",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "form-data": "^4.0.6",
    "multer": "^2.2.0",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "timeout": "2m",
    "verbose": true,
    "nodeArguments": [
      "--no-warnings"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "test/**",
      "node_modules/**"
    ],
    "all": true
  }
}
