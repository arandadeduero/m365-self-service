# Azure/Entra ID Configuration
# Get these values from Azure Portal after registering your application

# Application (client) ID - Found in App Registration Overview
CLIENT_ID=your-application-client-id-here

# Client Secret Value - Create in Certificates & Secrets (copy immediately!)
CLIENT_SECRET=your-client-secret-value-here

# Directory (tenant) ID - Found in App Registration Overview
TENANT_ID=your-tenant-id-here

# Application Configuration
# Local development redirect URI
REDIRECT_URI=http://localhost:3000/auth/callback

# Session secret - Generate with: openssl rand -base64 32
SESSION_SECRET=generate-a-random-secret-string-here

# Port for local development
PORT=3000

# Environment (development or production)
NODE_ENV=development

# WordPress Configuration
WP_URL=https://tu-sitio-wordpress.es
WP_USER=nombre_usuario_wp
WP_APP_PASSWORD=tu_token_generado
JETPACK_POST_BY_EMAIL=zzzzzzzzz@post.wordpress.com

# AWS SES Configuration
AWS_REGION=your-aws-region-here
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
FROM_EMAIL=your-verified-ses-sender-email-here

# Token Secret for Reset Password (generate with: openssl rand -base64 32)
TOKEN_SECRET=generate-a-random-secret-string-here
